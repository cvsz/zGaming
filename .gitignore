# zGaming — Bank-Grade .gitignore (enforced)
node_modules/
**/node_modules/
.turbo/
**/.turbo/
dist/
**/dist/
build/
**/build/
coverage/
logs/
pids/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env (keep examples)
.env
.env.*
!.env.example
!.env.production.example

# Generated / artifacts
installer/reports/install-*.jsonl
installer/artifacts/release/*.zip
reports/
*.zip
*.tar.gz

# OS / editor
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# Financial / never commit
**/wallet_ledger_backup.sql
**/*.key
**/*.pem
